layout_contract layout_settings_workspace {
  name "Settings Workspace Layout"
  description "Settings layout with navigation, settings sections, and contextual detail panels."
  parent layout_standard_app_shell
  fills content
  platforms [web ios android]
  viewports [wide narrow]
  domain dom_ui_work_map_proof
  status active

  region {
    id filters
    uses region_filter_rail
    viewport wide
    placement start
    pattern primary_navigation
  }

  region {
    id settings
    uses region_results
    slot true
    viewport any
    placement primary
    pattern settings_section
  }

  region {
