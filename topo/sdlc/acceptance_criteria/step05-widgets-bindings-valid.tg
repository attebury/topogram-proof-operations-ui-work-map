acceptance_criterion ac_step05_widgets_bindings_valid {
  name "Step 05 Widgets Bindings Valid"
  description "Given reusable screens and layouts already exist, when npm run verify is executed at Step 05, then semantic widgets validate, bind into inherited layout regions, and produce widget-focused proof artifacts without each screen restating every region."
  requirement req_operations_ui_work_map_proof
  status approved
}
