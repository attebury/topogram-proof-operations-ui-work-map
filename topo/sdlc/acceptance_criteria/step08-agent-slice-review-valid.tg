acceptance_criterion ac_step08_agent_slice_review_valid {
  name "Step 08 Agent Slice Review Valid"
  description "Given the operations UI work map contains layouts, regions, widgets, design realization sets, messages, and accessibility obligations, when npm run verify is executed at Step 08, then screen, widget, projection, layout, region, and design realization review artifacts show what an agent can use directly and what still needs better focused slice support."
  requirement req_operations_ui_work_map_proof
  status approved
}
