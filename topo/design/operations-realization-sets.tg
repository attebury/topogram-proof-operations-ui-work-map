design_realization_set realization_set_operations_control_room_widgets {
  name "Operations Control Room Widget Realizations"
  description "Maps operations semantic widgets to platform component refs across web, iOS, and Android."
  design_contract design_operations_product_ui
  related_terms [term_design_contract term_design_realization_set term_component_ref term_widget]
  domain dom_ui_work_map_proof
  status active

  widget_realization {
    id command_toolbar_web_wide
    widget widget_command_toolbar
    platform web
    viewport wide
    component_ref "ops.commandToolbar.desktop"
    pattern action_bar
    density compact
    state_coverage [loading empty error]
    role_contexts [operator manager]
    theme_contexts [light dark]
    locale_contexts [default_locale]
    status rendered
    behaviors_rendered [bulk_action keyboard_navigation]
  }

  widget_realization {
    id command_toolbar_web_narrow
    widget widget_command_toolbar
    platform web
    viewport narrow
    component_ref "ops.commandToolbar.overflow"
    pattern action_bar
    density compact
    state_coverage [loading empty error]
    role_contexts [operator]
    theme_contexts [light dark]
    locale_contexts [default_locale]
    status rendered
    behaviors_rendered [keyboard_navigation]
    behaviors_contract_only [bulk_action]
  }

  widget_realization {
    id command_toolbar_ios
    widget widget_command_toolbar
    platform ios
    viewport any
    component_ref "ops.ios.commandBar"
    pattern action_bar
    density comfortable
    state_coverage [loading empty error]
    role_contexts [operator]
    theme_contexts [system]
    locale_contexts [default_locale]
    status implementation_owned
    behaviors_rendered [keyboard_navigation]
    behaviors_implementation_owned [bulk_action]
  }

