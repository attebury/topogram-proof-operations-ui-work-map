design_realization_set realization_set_operations_review_gap_probe {
  name "Operations Review Gap Probe Realizations"
  description "Intentionally incomplete design mapping used by the proof to show missing token diagnostics."
  design_contract design_operations_review_gap_probe
  related_terms [term_design_contract term_design_realization_set term_component_ref]
  domain dom_ui_work_map_proof
  status proposed

  widget_realization {
    id alert_banner_gap_probe
    widget widget_alert_banner
    platform web
    viewport wide
    component_ref "ops.reviewGap.liveAlert"
    pattern activity_feed
    density compact
    state_coverage [loading]
    role_contexts [operator]
    theme_contexts [light]
    locale_contexts [default_locale]
    review_notes "Intentional Step 06 review row: this design contract has no token mappings."
    status contract_only
    behaviors_contract_only [realtime_update]
  }
}
